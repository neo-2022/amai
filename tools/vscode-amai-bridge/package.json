{
  "name": "amai-vscode-bridge",
  "displayName": "Amai VS Code Bridge",
  "description": "VS Code bridge for Amai. Requires a separate Amai install and a compatible chat extension.",
  "version": "0.0.7",
  "publisher": "amai",
  "icon": "media/amai-extension.png",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/neo-2022/amai.git",
    "directory": "tools/vscode-amai-bridge"
  },
  "homepage": "https://github.com/neo-2022/amai/tree/main/tools/vscode-amai-bridge",
  "bugs": {
    "url": "https://github.com/neo-2022/amai/issues"
  },
  "files": [
    "extension.js",
    "media/**",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "categories": [
    "Chat",
    "Other"
  ],
  "keywords": [
    "amai",
    "chat",
    "mcp",
    "continuity",
    "restore"
  ],
  "activationEvents": [
    "onUri",
    "onCommand:amaiVscodeBridge.openCleanChat",
    "onCommand:amaiVscodeBridge.openWorkspaceSidebarChat",
    "onCommand:amaiVscodeBridge.openWorkspacePanelChat",
    "onCommand:amaiVscodeBridge.openManagedRepoWorkspace",
    "onCommand:amaiVscodeBridge.openOpenAiExtension",
    "onCommand:amaiVscodeBridge.reloadWindow",
    "onView:amai.sidebar"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "amai",
          "title": "Amai",
          "icon": "media/amai-activity.svg"
        }
      ]
    },
    "views": {
      "amai": [
        {
          "id": "amai.sidebar",
          "name": "Amai",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "amaiVscodeBridge.openCleanChat",
        "title": "Amai: Open Clean Chat"
      },
      {
        "command": "amaiVscodeBridge.openWorkspaceSidebarChat",
        "title": "Amai: Open Workspace Chat in Sidebar"
      },
      {
        "command": "amaiVscodeBridge.openWorkspacePanelChat",
        "title": "Amai: Open Workspace Chat in Panel"
      },
      {
        "command": "amaiVscodeBridge.focusSidebarView",
        "title": "Amai: Focus Sidebar"
      },
      {
        "command": "amaiVscodeBridge.openManagedRepoWorkspace",
        "title": "Amai: Open Amai Repo"
      },
      {
        "command": "amaiVscodeBridge.openOpenAiExtension",
        "title": "Amai: Open Chat Extension"
      },
      {
        "command": "amaiVscodeBridge.reloadWindow",
        "title": "Amai: Reload Window"
      }
    ]
  }
}
