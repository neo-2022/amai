AMI_STACK_NAME=amai

AMI_PG_HOST=127.0.0.1
AMI_PG_PORT=55432
AMI_PG_DB=agent_memory_index
AMI_PG_USER=ami_admin
AMI_PG_PASSWORD=ami_admin_change_me

AMI_APP_DB_USER=ami_app
AMI_APP_DB_PASSWORD=ami_app_change_me

AMI_POSTGRES_DSN=postgresql://ami_admin:ami_admin_change_me@127.0.0.1:55432/agent_memory_index
AMI_APP_POSTGRES_DSN=postgresql://ami_app:ami_app_change_me@127.0.0.1:55432/agent_memory_index

AMI_QDRANT_URL=http://127.0.0.1:56334
AMI_QDRANT_HTTP_URL=http://127.0.0.1:56333
AMI_QDRANT_COLLECTION_CODE=code_chunks_v1
AMI_BENCHMARK_QDRANT_HTTP_URL=http://127.0.0.1:6333
AMI_BENCHMARK_QDRANT_COLLECTION_CODE=QdrantLocalCollection
AMI_QDRANT_ALIAS_CODE=code_chunks_active
AMI_QDRANT_COLLECTION_MEMORY=memory_cards_v1
AMI_QDRANT_ALIAS_MEMORY=memory_cards_active
AMI_QDRANT_CODE_DIM=768
AMI_QDRANT_MEMORY_DIM=384
AMI_QDRANT_DISTANCE=cosine

AMI_S3_ENDPOINT=http://127.0.0.1:59000
AMI_S3_REGION=us-east-1
AMI_S3_ACCESS_KEY=minioadmin
AMI_S3_SECRET_KEY=minioadmin
AMI_S3_BUCKET_ARTIFACTS=ami-artifacts
AMI_S3_BUCKET_TRANSCRIPTS=ami-transcripts
AMI_S3_BUCKET_CONTEXT=ami-context-packs

AMI_NATS_URL=nats://127.0.0.1:54222
AMI_NATS_HTTP_URL=http://127.0.0.1:58222

AMI_CODE_EMBED_MODEL=jina_base_code
AMI_MEMORY_EMBED_MODEL=multilingual_e5_small
AMI_CHUNK_MAX_BYTES=3200
AMI_FALLBACK_CHUNK_LINES=120
AMI_FALLBACK_CHUNK_OVERLAP_LINES=20
AMI_EDGE_CACHE_PATH=state/sqlite/edge_cache.sqlite3

AMI_STACK_PROFILE=default
AMI_DEFAULT_RETRIEVAL_MODE=local_strict
AMI_LOCAL_FAST_CACHE_TTL_MS=2000
AMI_OBSERVE_BIND=0.0.0.0:9464
AMI_PROMETHEUS_IMAGE=prom/prometheus:latest
AMI_PROMETHEUS_PORT=59090
AMI_PROMETHEUS_SCRAPE_TARGET=host.docker.internal:9464
AMI_QDRANT_SCRAPE_TARGET=qdrant:6333
AMI_GRAFANA_IMAGE=grafana/grafana:latest
AMI_GRAFANA_PORT=53000
AMI_GRAFANA_ADMIN_USER=admin
AMI_GRAFANA_ADMIN_PASSWORD=admin_change_me
AMI_GRAFANA_PROMETHEUS_URL=http://prometheus:9090
AMI_WARMUP_PROJECTS=
AMI_WARMUP_NAMESPACE=default
AMI_WARMUP_QUERY=README
AMI_WARMUP_RETRIEVAL_MODE=

# Optional tokenonomics truth sources for future reconciliation / pricing work.
# Keep them empty until you have explicit provider exports and a versioned rate-card file.
AMAI_PROVIDER_USAGE_EXPORT_PATH=
AMAI_PROVIDER_INVOICE_EXPORT_PATH=
AMAI_PROVIDER_RATE_CARD_PATH=
AMAI_INFRA_COST_PROFILE_PATH=
