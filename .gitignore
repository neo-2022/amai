state/qdrant/*
!state/qdrant/.gitkeep
state/minio/*
!state/minio/.gitkeep
state/nats/*
!state/nats/.gitkeep
state/sqlite/*
!state/sqlite/.gitkeep

tmp/*
!tmp/.gitkeep

.vscode/
.cursor/
